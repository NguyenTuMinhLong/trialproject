# === Database ===
DATABASE_URL=postgres://postgres:123@127.0.0.1:5000/sassy

# === Server ===
PORT=3000
NODE_ENV=development

# === JWT ===
JWT_SECRET=super-secret-key-change-this-in-production
REFRESH_SECRET=another-super-secret-key-change-this

# === Client URL (để CORS) ===
CLIENT_URL=http://localhost:5173

# === Email (SMTP) - Dùng Gmail để test ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# === OAuth (Google & GitHub) - để sau cũng được, tạm để trống ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=