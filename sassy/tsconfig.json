{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@server/*": ["packages/server/src/*"],
      "@client/*": ["packages/client/src/*"]
    }
  },
  "references": [
    { "path": "./packages/server" },
    { "path": "./packages/client" }
  ],
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "dist"]
}